JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# Set true for local Docker demos without Razorpay subscription enforcement.
BYPASS_PAYMENT=true

# Required for AI features.
GEMINI_API_KEY=

# Required when BYPASS_PAYMENT=false.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_PLAN_ID=
RAZORPAY_WEBHOOK_SECRET=
